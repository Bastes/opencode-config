{
  "$schema": "https://opencode.ai/config.json",
  "model": "qwen3-coder:30b-a3b-q4_K_M-16384",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b",
          "reasoning": true,
          "tools": true
        },
        "qwen3.5:35b-a3b-16384": {
          "name": "qwen3.5:35b-a3b-16384",
          "reasoning": true,
          "tools": true
        },
        "qwen3.6:35b-a3b-16384": {
          "name": "qwen3.6:35b-a3b-16384",
          "reasoning": true,
          "tools": true
        },
        "qwen3-coder:30b-a3b-q4_K_M-16384": {
          "name": "qwen3-coder:30b-a3b-q4_K_M-16384",
          "reasoning": true,
          "tools": true
        },
        "sam860/lucy:1.7b": {
          "name": "sam860/lucy:1.7b",
          "reasoning": true,
          "tools": true
        },
      }
    }
  },
  "permission": {
    "*": "ask"
  },
  "agent": {
    "coder": {
      "mode": "primary",
      "model": "ollama/qwen3.6:35b-a3b-16384",
      "prompt": "You are a Coder agent - a skilled programmer tasked with analyzing codebases and implementing solutions. You have access to all tools and should execute user prompts that involve programming tasks. Focus on writing clean, efficient code and using the appropriate tools to complete the requested tasks.",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "temperature": 0.2
    },
    "researcher": {
      "mode": "subagent",
      "model": "ollama/sam860/lucy:1.7b",
      "prompt": "You are a Researcher agent - a skilled researcher tasked with analyzing information, conducting research, and providing well-researched insights. You have reasoning capabilities and tool access to support your research tasks.",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "temperature": 0.7
    }
  }
}
