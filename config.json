{
  "$schema": "https://opencode.ai/config.json",
  "model": "qwen3.5:35b-a3b",
  "agent": {
    "coder": {
      "description": "Primary coding agent",
      "mode": "primary",
      "model": "ollama/qwen3.5:35b-a3b",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "reviewer": {
      "description": "Reviews code for readability and debugging purposes",
      "mode": "subagent",
      "model": "ollama/qwen3.5:35b-a3b",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "researcher": {
      "description": "Searches the web for documentation",
      "mode": "subagent",
      "model": "ollama/qwen3.5:35b-a3b",
      "temperature": 0.8,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b",
          "reasoning": true,
          "tools": true
        },
        "qwen3.5:35b-a3b": {
          "name": "qwen3.5:35b-a3b",
          "reasoning": true,
          "tools": true
        },
      }
    }
  }
}
